# === Обязательные ===
BOT_TOKEN=
ADMIN_ID=
CHANNEL_ID=

# === Настройки публикации ===
# Время ежедневного поста (HH:MM, в часовом поясе TZ)
POST_TIME=10:00
# Публиковать в канал без одобрения администратора (true/false)
AUTO_PUBLISH=false

# === База данных ===
DATABASE_PATH=winebot.db
# Сколько дней не повторять одно и то же вино
HISTORY_DAYS=90

# === Scraping ===
MAX_CANDIDATES=10

# === Прочее ===
TZ=Asia/Yekaterinburg
DEBUG=false
